/* ========================================
   五行力量仪表盘
   ======================================== */

.wuxing-chart {
  padding: var(--spacing-sm) 0;
}

.chart-title {
  font-size: 26rpx;
  letter-spacing: 4rpx;
  margin-bottom: var(--spacing-md);
}

/* ---- 每行 ---- */
.chart-row {
  display: flex;
  align-items: center;
  height: 56rpx;
  margin-bottom: 4rpx;
}

.chart-label {
  display: flex;
  align-items: center;
  width: 120rpx;
  gap: 6rpx;
}

.chart-icon {
  font-size: 24rpx;
}

.chart-name {
  font-size: 26rpx;
  font-weight: 500;
}

/* ---- 进度条容器 ---- */
.chart-bar-wrap {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 var(--spacing-md);
}

.chart-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 0 6rpx currentColor;
}

.bar-empty {
  border: 2rpx dashed rgba(255, 255, 255, 0.12);
  background: transparent !important;
}

/* ---- 数值 ---- */
.chart-value {
  width: 80rpx;
  font-size: 26rpx;
  font-family: var(--font-mono);
  text-align: right;
}

.value-missing {
  color: #C04A3A;
  font-size: 22rpx;
}

/* ---- 平衡评语 ---- */
.balance-comment {
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm);
  font-size: 24rpx;
  line-height: 1.6;
}
