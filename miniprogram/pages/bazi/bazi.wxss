/* ========================================
   命盘页面 · 完整样式
   ======================================== */

.bazi-page {
  min-height: 100vh;
  position: relative;
  z-index: 1;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1F2B 100%);
}

/* ---- 吸顶导航栏 ---- */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(12, 12, 12, 0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  transition: box-shadow 0.3s ease;
}

.nav-shadow {
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.5);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  padding: 0 var(--spacing-lg);
}

.nav-title {
  font-size: 34rpx;
  letter-spacing: 8rpx;
}

.nav-history {
  position: absolute;
  right: var(--spacing-lg);
  font-size: 32rpx;
}

/* ---- 滚动容器 ---- */
.bazi-scroll {
  height: 100vh;
}

.content-padding {
  padding: 0 var(--spacing-md);
}

/* ---- 输入区 ---- */
.input-section {
  margin-top: var(--spacing-md);
}

.section-title {
  font-size: 30rpx;
  letter-spacing: 4rpx;
  margin-bottom: var(--spacing-md);
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.04);
  border: var(--border-gold);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacing-md);
  height: 84rpx;
}

.date-text {
  font-size: 30rpx;
  font-family: var(--font-mono);
}

.date-icon {
  font-size: 32rpx;
}

.input-hint {
  font-size: 22rpx;
  text-align: center;
  padding: 8rpx 0;
}

/* ---- 加载 ---- */
.loading-icon {
  display: inline-block;
  animation: spin 1s linear infinite;
  font-size: 32rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ---- 快捷日期栏 ---- */
.quick-date-bar {
  height: 80rpx;
  background: var(--bg-card);
  border: var(--border-subtle);
  border-radius: var(--radius-card);
  padding: 0 var(--spacing-md);
}

.quick-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 50%;
}

.quick-arrow:active {
  background: rgba(212, 175, 55, 0.12);
  color: var(--color-gold);
}

.quick-date-info {
  flex: 1;
  font-size: 26rpx;
}

.btn-today {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border: var(--border-gold);
  border-radius: var(--radius-sm);
}

.btn-today:active {
  background: rgba(212, 175, 55, 0.1);
}

/* ---- 空态 ---- */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.2;
  animation: spin 20s linear infinite;
}

/* ---- 通用 ---- */
.my-md {
  margin-top: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.px-md {
  padding-left: var(--spacing-md);
  padding-right: var(--spacing-md);
}
