.zhiku-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1F2B 100%);
  position: relative;
  z-index: 1;
}

.zhiku-content {
  padding: 40rpx var(--spacing-md);
}

.section-header {
  font-size: 30rpx;
  letter-spacing: 4rpx;
  margin-bottom: var(--spacing-md);
}

/* ---- 大师列表 ---- */
.master-list {
  white-space: nowrap;
  padding: var(--spacing-sm) 0;
}

.master-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  padding: var(--spacing-md);
  background: rgba(255, 255, 255, 0.03);
  border: var(--border-subtle);
  border-radius: var(--radius-card);
  margin-right: var(--spacing-md);
}

.master-avatar {
  font-size: 56rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(212, 175, 55, 0.1);
  border-radius: 50%;
  border: var(--border-gold);
}

.master-name {
  font-size: 24rpx;
  color: var(--text-primary);
  margin-top: 8rpx;
}

.master-skill {
  font-size: 20rpx;
  margin-top: 4rpx;
}

.master-stars {
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* ---- 技能商城 ---- */
.skill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.skill-card {
  width: calc(50% - 12rpx);
  padding: var(--spacing-md);
  background: rgba(255, 255, 255, 0.03);
  border: var(--border-subtle);
  border-radius: var(--radius-card);
  text-align: center;
  position: relative;
  box-sizing: border-box;
}

.skill-emoji {
  font-size: 48rpx;
}

.skill-name {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-top: 8rpx;
}

.skill-price {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

.skill-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: var(--color-gold);
  background: rgba(212, 175, 55, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.mt-xl { margin-top: 48rpx; }
