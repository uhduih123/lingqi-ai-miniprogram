.zhiku-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1F2B 100%);
  position: relative;
  z-index: 1;
}

/* 标签 */
.zhiku-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}
.zhiku-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
  background: rgba(255,255,255,0.04);
  border-radius: 24rpx;
  transition: all 0.25s;
}
.tab-active {
  color: var(--color-gold);
  background: rgba(212,175,55,0.12);
  border: 1rpx solid rgba(212,175,55,0.3);
}

.zhiku-scroll { height: calc(100vh - 120rpx); padding: 0 32rpx; }

/* 大师卡片 */
.master-list { display: flex; flex-direction: column; gap: 16rpx; }
.master-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
}
.master-card:active { background: rgba(255,255,255,0.06); }
.master-avatar {
  width: 100rpx; height: 100rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
  background: rgba(212,175,55,0.08);
  border-radius: 50%;
}
.master-right { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.master-top { display: flex; justify-content: space-between; align-items: center; }
.master-name { font-size: 30rpx; color: #ddd; font-family: var(--font-title); }
.master-stars { font-size: 22rpx; }
.master-skill { font-size: 24rpx; }
.master-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.master-tag {
  font-size: 18rpx;
  color: var(--color-gold);
  background: rgba(212,175,55,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.master-bottom { display: flex; justify-content: space-between; }
.master-rate { font-size: 28rpx; font-weight: 600; }
.master-orders { font-size: 22rpx; }

/* 技能卡片 */
.skill-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.skill-card {
  width: calc(50% - 8rpx);
  padding: 28rpx 20rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  box-sizing: border-box;
}
.skill-card:active { background: rgba(255,255,255,0.06); }
.skill-emoji { font-size: 52rpx; }
.skill-name { display: block; font-size: 28rpx; color: #ddd; margin-top: 12rpx; }
.skill-desc {
  display: block; font-size: 20rpx; margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.skill-footer {
  display: flex; justify-content: space-between; align-items: center; margin-top: 14rpx;
}
.skill-price { font-size: 28rpx; font-weight: 600; }
.skill-sold { font-size: 20rpx; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.modal-show { opacity: 1; pointer-events: auto; }
.modal-content {
  width: 100%;
  background: #1A1A1A;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  position: relative;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  transform: translateY(20rpx); transition: transform 0.35s ease;
}
.modal-show .modal-content { transform: translateY(0); }
.modal-close {
  position: absolute; top: 24rpx; right: 32rpx;
  font-size: 32rpx; color: var(--text-muted); padding: 8rpx 16rpx;
}

/* 大师弹窗 */
.master-modal-avatar { font-size: 80rpx; }
.master-modal-name { font-size: 36rpx; color: #ddd; font-family: var(--font-title); }
.master-modal-skill { font-size: 26rpx; }
.master-modal-stars { display: flex; gap: 8rpx; font-size: 28rpx; }
.master-modal-intro { font-size: 26rpx; line-height: 1.6; text-align: center; }
.master-modal-tags { display: flex; gap: 8rpx; flex-wrap: wrap; justify-content: center; }

/* 技能弹窗 */
.skill-modal { gap: 12rpx; }
.skill-modal-emoji { font-size: 90rpx; }
.skill-modal-name { font-size: 34rpx; color: #ddd; font-family: var(--font-title); }
.skill-modal-desc { font-size: 26rpx; text-align: center; line-height: 1.5; }
.skill-modal-info {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  margin: 8rpx 0;
}

/* 通用按钮 */
.modal-btn {
  width: 100%; height: 88rpx; margin-top: 8rpx;
}
