<star-bg />
<view class="zhiku-page">
  <view class="zhiku-content">
    
    <!-- 大师咨询 -->
    <view class="section-header text-serif text-gold">✦ 大师咨询</view>
    <scroll-view class="master-list" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="master-card" wx:for="{{masters}}" wx:key="id">
        <view class="master-avatar">{{item.avatar}}</view>
        <view class="master-name">{{item.name}}</view>
        <view class="master-skill text-muted">{{item.skill}}</view>
        <view class="master-stars text-gold">{{item.stars}}</view>
      </view>
    </scroll-view>
    
    <!-- 技能商城 -->
    <view class="section-header text-serif text-gold mt-xl">✦ 玄学技能</view>
    <view class="skill-grid">
      <view class="skill-card" wx:for="{{skills}}" wx:key="id">
        <view class="skill-emoji">{{item.emoji}}</view>
        <view class="skill-name">{{item.name}}</view>
        <view class="skill-price text-gold">{{item.price}}</view>
        <view class="skill-badge">内测中</view>
      </view>
    </view>
    
    <view class="text-center mt-xl" style="padding-bottom: 100rpx;">
      <text class="text-muted">更多技能即将上线 · 敬请期待</text>
    </view>
  </view>
</view>
