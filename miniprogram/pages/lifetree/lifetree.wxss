/* ========================================
   人生树页面
   水墨线条风格
   ======================================== */

.lifetree-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A2A1F 100%);
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tree-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 100rpx;
}

/* ---- 树木画布 ---- */
.tree-visual {
  position: relative;
  width: 560rpx;
  height: 640rpx;
}

/* ---- 树干 ---- */
.tree-trunk {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 260rpx;
  background: linear-gradient(to top, rgba(255,255,255,0.25), rgba(255,255,255,0.08));
  border-radius: 6rpx;
}

/* ---- 树根 ---- */
.tree-roots {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 40rpx;
}

.root {
  position: absolute;
  bottom: 0;
  height: 40rpx;
  width: 4rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 2rpx;
  transform-origin: top center;
}
.root-1 { left: 20rpx; transform: rotate(25deg); }
.root-2 { left: 38rpx; transform: rotate(0deg); }
.root-3 { left: 56rpx; transform: rotate(-25deg); }

/* ---- 分支公共 ---- */
.tree-branch {
  position: absolute;
}

/* 分支连线 */
.branch-line {
  position: absolute;
  background: rgba(255,255,255,0.12);
  border-radius: 2rpx;
  transform-origin: top left;
}

/* ---- 分支1 学业 - 左上 ---- */
.branch-1 {
  right: 55%;
  bottom: 250rpx;
}
.branch-1 .branch-line {
  width: 120rpx;
  height: 3rpx;
  top: 50%;
  left: 30rpx;
  transform: rotate(-30deg);
}
.branch-1 .branch-node {
  margin-left: -20rpx;
}

/* ---- 分支2 事业 - 右上 ---- */
.branch-2 {
  left: 55%;
  bottom: 310rpx;
}
.branch-2 .branch-line {
  width: 130rpx;
  height: 3rpx;
  top: 50%;
  right: 30rpx;
  transform: rotate(25deg);
  left: auto;
  transform-origin: top right;
}
.branch-2 .branch-node {
  margin-right: -20rpx;
}

/* ---- 分支3 姻缘 - 左中 ---- */
.branch-3 {
  right: 58%;
  bottom: 340rpx;
}
.branch-3 .branch-line {
  width: 100rpx;
  height: 3rpx;
  top: 50%;
  left: 20rpx;
  transform: rotate(-15deg);
}
.branch-3 .branch-node {
  margin-left: -10rpx;
}

/* ---- 分支4 健康 - 右中 ---- */
.branch-4 {
  left: 58%;
  bottom: 380rpx;
}
.branch-4 .branch-line {
  width: 110rpx;
  height: 3rpx;
  top: 50%;
  right: 20rpx;
  transform: rotate(20deg);
  left: auto;
  transform-origin: top right;
}
.branch-4 .branch-node {
  margin-right: -10rpx;
}

/* ---- 节点卡片 ---- */
.branch-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0,0,0,0.7);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: var(--radius-card);
  padding: 16rpx 24rpx;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.branch-node:active {
  transform: scale(0.95);
  border-color: rgba(212, 175, 55, 0.4);
}

.node-icon {
  font-size: 44rpx;
}

.node-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-family: var(--font-title);
  margin-top: 6rpx;
}

.node-tag {
  font-size: 18rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ---- 树冠叶子 ---- */
.tree-canopy {
  position: absolute;
  top: 20rpx;
  left: 0;
  width: 100%;
  height: 200rpx;
}

.leaf {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(143,188,143,0.3), rgba(143,188,143,0.05));
  animation: leafSway 4s ease-in-out infinite;
}

.leaf-1 { top: 40rpx; left: 30%; animation-delay: 0s; }
.leaf-2 { top: 20rpx; left: 45%; width: 50rpx; height: 50rpx; animation-delay: 0.8s; }
.leaf-3 { top: 50rpx; left: 60%; animation-delay: 1.6s; }
.leaf-4 { top: 70rpx; left: 25%; width: 35rpx; height: 35rpx; animation-delay: 2.4s; }
.leaf-5 { top: 30rpx; left: 70%; animation-delay: 3.2s; }
.leaf-6 { top: 80rpx; left: 50%; width: 45rpx; height: 45rpx; animation-delay: 0.4s; }

@keyframes leafSway {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.4; }
  50% { transform: translateY(-6rpx) rotate(5deg); opacity: 0.7; }
}

/* ---- 底部文字 ---- */
.tree-caption {
  margin-top: 40rpx;
  font-size: 24rpx;
  font-family: var(--font-title);
  letter-spacing: 8rpx;
}
