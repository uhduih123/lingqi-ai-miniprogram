<star-bg />
<view class="lifetree-page">
  <view class="tree-container">
    
    <!-- 水墨树 -->
    <view class="tree-visual">
      
      <!-- 树根 -->
      <view class="tree-roots">
        <view class="root root-1"></view>
        <view class="root root-2"></view>
        <view class="root root-3"></view>
      </view>
      
      <!-- 树干 -->
      <view class="tree-trunk"></view>
      
      <!-- 分支1 - 学业 (左上) -->
      <view class="tree-branch branch-1">
        <view class="branch-line"></view>
        <view class="branch-node">
          <text class="node-icon">🎓</text>
          <text class="node-label">学业</text>
          <text class="node-tag">{{'已连接'}}</text>
        </view>
      </view>
      
      <!-- 分支2 - 事业 (右上) -->
      <view class="tree-branch branch-2">
        <view class="branch-line"></view>
        <view class="branch-node">
          <text class="node-icon">💼</text>
          <text class="node-label">事业</text>
          <text class="node-tag">即将上线</text>
        </view>
      </view>
      
      <!-- 分支3 - 姻缘 (左下) -->
      <view class="tree-branch branch-3">
        <view class="branch-line"></view>
        <view class="branch-node">
          <text class="node-icon">💕</text>
          <text class="node-label">姻缘</text>
          <text class="node-tag">即将上线</text>
        </view>
      </view>
      
      <!-- 分支4 - 健康 (右下) -->
      <view class="tree-branch branch-4">
        <view class="branch-line"></view>
        <view class="branch-node">
          <text class="node-icon">🏥</text>
          <text class="node-label">健康</text>
          <text class="node-tag">即将上线</text>
        </view>
      </view>
      
      <!-- 树冠叶子 -->
      <view class="tree-canopy">
        <view class="leaf leaf-1"></view>
        <view class="leaf leaf-2"></view>
        <view class="leaf leaf-3"></view>
        <view class="leaf leaf-4"></view>
        <view class="leaf leaf-5"></view>
        <view class="leaf leaf-6"></view>
      </view>
      
    </view>
    
    <view class="tree-caption text-muted">
      命理之树 · 伴你生长
    </view>
  </view>
</view>
