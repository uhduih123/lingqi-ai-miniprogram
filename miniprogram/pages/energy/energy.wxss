.energy-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1A2E 100%);
  position: relative; z-index: 1;
}
.energy-scroll { height: 100vh; padding: 24rpx 32rpx; }

/* 每日磁场 */
.daily-section { 
  margin-bottom: 24rpx; padding: 24rpx;
  background: linear-gradient(135deg, rgba(212,175,55,0.05), rgba(0,0,0,0.3));
}
.daily-header { display: flex; align-items: center; gap: 12rpx; }
.daily-emoji { font-size: 48rpx; }
.daily-level { font-size: 36rpx; font-family: var(--font-title); font-weight: bold; }
.daily-hint { font-size: 24rpx; margin-top: 12rpx; line-height: 1.5; }
.daily-tips { display: flex; justify-content: space-between; margin-top: 16rpx; }
.daily-tip { display: flex; gap: 8rpx; font-size: 24rpx; }

/* 能量球 */
.sphere-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 0;
}
.energy-sphere {
  width: 320rpx; height: 320rpx; position: relative;
  display: flex; align-items: center; justify-content: center;
}
.sphere-bounce { animation: sphereBounce 0.8s ease; }
@keyframes sphereBounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.12); }
  60% { transform: scale(0.95); }
  100% { transform: scale(1); }
}
.sphere-glow {
  position: absolute; top: 50%; left: 50%;
  width: 260rpx; height: 260rpx;
  border-radius: 50%; border: 2rpx solid;
  transform: translate(-50%, -50%);
  animation: glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse {
  0%,100% { box-shadow: 0 0 20rpx currentColor; }
  50% { box-shadow: 0 0 40rpx currentColor; }
}
.sphere-core {
  width: 140rpx; height: 140rpx;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  z-index: 2; animation: coreSpin 12s linear infinite;
}
@keyframes coreSpin {
  to { transform: rotate(360deg); }
}
.sphere-icon { font-size: 70rpx; color: var(--color-gold); }
.sphere-ring {
  position: absolute; top: 50%; left: 50%;
  border-radius: 50%; border: 1rpx solid;
  transform: translate(-50%, -50%);
  animation: ringRotate linear infinite;
}
.ring-1 { width: 290rpx; height: 290rpx; animation-duration: 8s; }
.ring-2 { width: 350rpx; height: 350rpx; animation-duration: 14s; animation-direction: reverse; }
@keyframes ringRotate {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}
.sphere-particle {
  position: absolute; font-size: 14rpx;
  animation: particleOrbit 7s linear infinite;
}
.p1 { animation-duration: 6s; }
.p2 { animation-duration: 8s; animation-direction: reverse; }
.p3 { animation-duration: 9s; }
@keyframes particleOrbit {
  0% { transform: rotate(0deg) translateX(130rpx) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(130rpx) rotate(-360deg); }
}
.energy-info { text-align: center; margin-top: 20rpx; }
.energy-level-text { font-size: 56rpx; font-weight: bold; }
.energy-desc { font-size: 24rpx; margin-top: 4rpx; }
.tap-hint { font-size: 22rpx; margin-top: 12rpx; }

/* 签文生成 */
.fortune-btn { width: 500rpx; margin: 0 auto; }
.generating { display: flex; align-items: center; gap: 8rpx; }
.loading-icon { animation: spin 1s linear infinite; font-size: 32rpx; display: inline-block; }
@keyframes spin { to { transform: rotate(360deg); } }

.fortune-result {
  max-height: 0; overflow: hidden;
  transition: max-height 0.5s ease; margin-top: 24rpx;
}
.fortune-show { max-height: 800rpx; }
.fortune-card { padding: 32rpx; text-align: center; }
.fortune-qian { font-size: 36rpx; font-family: var(--font-title); font-weight: bold; }
.fortune-text {
  display: block; font-size: 28rpx; margin: 20rpx 0;
  line-height: 1.8; font-family: var(--font-title);
}
.fortune-advice { display: block; font-size: 24rpx; line-height: 1.6; }
.fortune-actions { margin-top: 20rpx; }
.fortune-save { width: 300rpx; margin: 0 auto; height: 64rpx; font-size: 24rpx; }

.saved-toggle { padding: 16rpx; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7); z-index: 200;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity 0.3s;
}
.modal-show { opacity: 1; pointer-events: auto; }
.modal-content {
  width: 100%; max-height: 70vh;
  background: #1A1A1A; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx; position: relative;
  transform: translateY(20rpx); transition: transform 0.35s;
}
.modal-show .modal-content { transform: translateY(0); }
.modal-close {
  position: absolute; top: 24rpx; right: 32rpx;
  font-size: 32rpx; color: var(--text-muted); padding: 8rpx 16rpx;
}
.saved-list { max-height: 50vh; }
.saved-item {
  padding: 20rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.saved-qian { font-size: 28rpx; font-family: var(--font-title); color: var(--color-gold); }
.saved-text { display: block; font-size: 24rpx; margin: 8rpx 0; line-height: 1.5; }
.saved-time { font-size: 20rpx; }
