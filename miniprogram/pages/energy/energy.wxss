.energy-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1A2E 100%);
  position: relative;
  z-index: 1;
}

.energy-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

/* ---- 能量球 ---- */
.energy-sphere {
  width: 360rpx;
  height: 360rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sphere-core {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  animation: corePulse 3s ease-in-out infinite;
}

@keyframes corePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.sphere-text {
  font-size: 80rpx;
}

.sphere-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  border: 1rpx solid rgba(212, 175, 55, 0.15);
  transform: translate(-50%, -50%);
  animation: ringRotate linear infinite;
}

.ring-1 {
  width: 280rpx;
  height: 280rpx;
  animation-duration: 8s;
}

.ring-2 {
  width: 340rpx;
  height: 340rpx;
  border-color: rgba(212, 175, 55, 0.08);
  animation-duration: 12s;
  animation-direction: reverse;
}

.ring-3 {
  width: 400rpx;
  height: 400rpx;
  border-color: rgba(212, 175, 55, 0.05);
  animation-duration: 16s;
}

@keyframes ringRotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

/* ---- 五行粒子 ---- */
.sphere-particle {
  position: absolute;
  font-size: 16rpx;
  animation: particleOrbit 6s linear infinite;
  opacity: 0.6;
}

.p1 { animation-duration: 6s; }
.p2 { animation-duration: 8s; animation-direction: reverse; }
.p3 { animation-duration: 7s; }
.p4 { animation-duration: 9s; animation-direction: reverse; }
.p5 { animation-duration: 7.5s; }

@keyframes particleOrbit {
  0% { transform: rotate(0deg) translateX(180rpx) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(180rpx) rotate(-360deg); }
}

/* ---- 按钮 ---- */
.energy-btns {
  margin-top: 80rpx;
  width: 500rpx;
}

.energy-btn {
  width: 100%;
}

.mt-xl { margin-top: 48rpx; }
