<star-bg />
<view class="energy-page">
  <view class="energy-content">
    
    <!-- 能量球 -->
    <view class="energy-sphere">
      <view class="sphere-core">
        <text class="sphere-text text-gold">☯</text>
      </view>
      <view class="sphere-ring ring-1"></view>
      <view class="sphere-ring ring-2"></view>
      <view class="sphere-ring ring-3"></view>
      <!-- 五行粒子 -->
      <view class="sphere-particle p1" style="color: #E5D3B3;">●</view>
      <view class="sphere-particle p2" style="color: #8FBC8F;">●</view>
      <view class="sphere-particle p3" style="color: #7BA4CC;">●</view>
      <view class="sphere-particle p4" style="color: #E08070;">●</view>
      <view class="sphere-particle p5" style="color: #C9A050;">●</view>
    </view>
    
    <!-- 按钮 -->
    <view class="energy-btns">
      <view class="btn-gold energy-btn" bindtap="onEnergyField">
        <text>⚡ 今日能量磁场</text>
      </view>
      <view class="btn-dark energy-btn mt-md" bindtap="onGenerator">
        <text>🎲 补运生成器</text>
      </view>
    </view>
    
    <view class="text-center mt-xl">
      <text class="text-muted">即将上线 · 敬请期待</text>
    </view>
  </view>
</view>
