.history-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0C0C0C 0%, #1A1F2B 100%);
  position: relative;
  z-index: 1;
}

.history-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(12,12,12,0.85);
  backdrop-filter: blur(20px);
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  position: relative;
}

.header-back {
  position: absolute;
  left: 32rpx;
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 8rpx;
}

.header-title {
  font-size: 32rpx;
  letter-spacing: 6rpx;
}

.header-clear {
  position: absolute;
  right: 32rpx;
  font-size: 26rpx;
  padding: 8rpx;
}

.history-scroll {
  height: 100vh;
  padding: 0 32rpx;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 30rpx;
  margin-top: 32rpx;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* 记录列表 */
.record-list {
  padding-top: 24rpx;
}

.record-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-date {
  font-size: 30rpx;
  font-family: var(--font-mono);
}

.record-lunar {
  font-size: 22rpx;
}

.record-delete {
  padding: 8rpx 12rpx;
  font-size: 32rpx;
}

.record-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-rizhu {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
}

.rizhu-value {
  font-size: 30rpx;
  font-family: var(--font-title);
  font-weight: bold;
}

.record-comment {
  font-size: 22rpx;
  max-width: 300rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 20rpx;
  margin-top: 12rpx;
  text-align: right;
}
