<star-bg />
<view class="history-page">
  <!-- 头部 -->
  <view class="history-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-content">
      <view class="header-back" bindtap="onBack">
        <text>←</text>
      </view>
      <text class="header-title text-serif text-gold">历史排盘</text>
      <view class="header-clear" bindtap="onClearAll" wx:if="{{!isEmpty}}">
        <text class="text-muted">清空</text>
      </view>
    </view>
  </view>

  <scroll-view class="history-scroll" scroll-y enhanced show-scrollbar="{{false}}"
    style="padding-top: {{headerHeight}}px;">
    
    <!-- 空态 -->
    <view class="empty-state" wx:if="{{isEmpty}}">
      <text class="empty-icon">📜</text>
      <text class="empty-text text-muted">暂无排盘记录</text>
      <text class="empty-hint text-muted">前往命盘页开始探索</text>
    </view>

    <!-- 记录列表 -->
    <view class="record-list" wx:else>
      <block wx:for="{{records}}" wx:key="index">
        <view class="record-card card-gold" 
              data-index="{{index}}"
              bindtap="onRecordTap">
          <view class="record-top">
            <view class="record-main">
              <text class="record-date text-gold">{{item.birthday}}</text>
              <text class="record-lunar text-muted">{{item.lunarDate}}</text>
            </view>
            <view class="record-delete" data-index="{{index}}" catchtap="onDeleteRecord">
              <text class="text-muted">🗑</text>
            </view>
          </view>
          <view class="divider-gold"></view>
          <view class="record-info">
            <view class="record-rizhu">
              <text class="text-secondary">日主</text>
              <text class="rizhu-value text-gold">{{item.rizhu}}</text>
            </view>
            <view class="record-comment">
              <text class="text-muted">{{item.comment}}</text>
            </view>
          </view>
          <view class="record-time text-muted">{{item.timeStr}}</view>
        </view>
      </block>
    </view>

    <view style="height: 80rpx;"></view>
  </scroll-view>
</view>
